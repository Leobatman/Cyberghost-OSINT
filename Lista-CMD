cyberghost tools --update               # Atualizar ferramentas
cyberghost tools --check                # Verificar saúde
cyberghost doctor                       # Diagnóstico do sistema
cyberghost test                         # Testar funcionalidades
cyberghost test --apis                  # Testar APIs

