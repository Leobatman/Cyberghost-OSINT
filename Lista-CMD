📜 LISTA COMPLETA DE COMANDOS - CYBERGHOST OSINT

🚀 COMANDOS PRINCIPAIS

🏁 INICIALIZAÇÃO
cyberghost                       # Menu interativo
cyberghost menu                  # Abrir menu principal
cyberghost --help                # Ajuda geral
cyberghost --version             # Ver versão

📥 INSTALAÇÃO E ATUALIZAÇÃO
cyberghost install               # Instalar tudo (30-60min)
cyberghost install --force       # Forçar instalação completa
cyberghost update                # Atualizar CyberGhost
cyberghost update --all          # Atualizar todas as ferramentas
cyberghost update --tools        # Atualizar apenas ferramentas

🔍 SCAN BÁSICO
cyberghost scan <target>         # Scan básico
cyberghost scan example.com      # Domínio
cyberghost scan 192.168.1.1      # IP
cyberghost scan @username        # Username
cyberghost scan email@dom.com    # Email

🎯 SCAN AVANÇADOS
cyberghost scan <target> full           # Todos módulos
cyberghost scan <target> recon          # Reconhecimento
cyberghost scan <target> social         # Redes sociais
cyberghost scan <target> business       # Business intel
cyberghost scan <target> threat         # Threat intel
cyberghost scan <target> github         # GitHub intel
cyberghost scan <target> email          # Email intel
cyberghost scan <target> mobile         # Mobile apps
cyberghost scan <target> dns            # DNS profundo

⚙️ OPÇÕES DE SCAN
cyberghost scan <target> --fast         # Modo rápido
cyberghost scan <target> --deep         # Modo profundo
cyberghost scan <target> --stealth      # Modo stealth
cyberghost scan <target> --quiet        # Silencioso
cyberghost scan <target> --verbose      # Detalhado
cyberghost scan <target> --threads=10   # Definir threads
cyberghost scan <target> --timeout=60   # Definir timeout

📊 BATCH PROCESSING
cyberghost batch <file.txt>             # Scan em lote
cyberghost batch targets.txt            # Arquivo com alvos
cyberghost batch <file> --concurrent=5  # Com concorrência
cyberghost batch <file> --resume        # Continuar batch

👁️ MONITORAMENTO
cyberghost monitor <target>             # Monitorar alvo
cyberghost monitor <target> --interval=6h   # Intervalo
cyberghost monitor <target> --alerts        # Com alertas
cyberghost monitor <target> --email=email@  # Alertas por email
cyberghost monitor --list               # Listar monitoramentos

📁 GESTÃO DE DADOS
cyberghost reports                      # Listar relatórios
cyberghost reports --clean-old          # Limpar relatórios antigos
cyberghost export <scan_dir> --format=json  # Exportar dados
cyberghost export <scan_dir> --format=csv   # Exportar CSV
cyberghost correlate <scan_dir>         # Correlacionar dados

🛠️ FERRAMENTAS AUXILIARES
